// backend/prisma/schema.prisma
// Add to existing schema; run:
//   npx prisma migrate dev --name add_visual_ingest

model Capture {
  id              Int       @id @default(autoincrement())
  capturedAt      DateTime
  mode            String    // DASHBOARD_ODOMETER | FUEL_PUMP | ANALOG_GAUGE | CHICKEN_HOUSE_LOG | GENERIC_LOG
  status          String    // COMPLETE | INCOMPLETE | INCONSISTENT | REJECTED | EDITED
  rawImagePath    String    // server-side path under CAPTURE_STORAGE_DIR
  parsedFields    String    @db.Text  // JSON (ParsedFields)
  linkedEntities  String    @db.Text  // JSON: { fuelLogId, mileageEntryId, chickenHouseLogId }
  farmId          String?
  latitude        Float?
  longitude       Float?
  createdAt       DateTime  @default(now())

  @@index([capturedAt])
  @@index([farmId])
  @@index([status])
  @@index([mode])
}
