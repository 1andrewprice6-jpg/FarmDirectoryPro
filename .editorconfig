root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
ij_kotlin_packages_to_use_import_on_demand = androidx.camera.core, androidx.compose.foundation.layout, androidx.compose.foundation.lazy, androidx.compose.material.icons.filled, androidx.compose.material3, androidx.compose.runtime, androidx.compose.ui, com.example.farmdirectoryupgraded.ui, java.util, kotlin
